days=-5 # set days you want to check


# Folder Paths -- Please add when necessary 
find /ds/production/*/deliverables/.failed -mtime $days -type f
find /ds/production/*/deliverables.rq/.failed -mtime $days -type f # Autohocs
find /ds/env/prod/*/common/deliverables/.failed -mtime $days -type f
find /ds/env/prod/*/deliverables/*/.failed -mtime $days -type f
find /ds/env/prod/*/incoming/.failed -mtime $days -type f
find /ds/env/prod/*/incoming/*/PROD/NOEProd/.failed -mtime $days -type f
find /ds/env/prod/*/incoming/*/PROD/.failed -mtime $days -type f
find /ds/incoming/*/prod/*/.failed/ -mtime $days -type f
find /ds/env/prod/*/outgoing/*/.failed -mtime $days -type f
find /ds/outgoing/production/*/deliverables.rq/.failed -mtime $days -type f 
find /ds/env/prod/*/outgoing/*/TEST/Error_Files/.failed -mtime $days -type f
find /ds/env/prod/*/outgoing/*/PROD/.failed -mtime $days -type f
find /ds/env/prod/*/outgoing/PPE/*/.failed -mtime $days -type f
find /ds/env/prod/*/common/submitter/retry/.failed -mtime $days -type f  
find /ds/env/prod/*/common/bin/pscbr_auto/retry/gf3_retry/.failed/ -mtime $days -type f # Path specifically to RHPS
find /ds/env/prod/*/incoming/*/.failed/ -mtime $days -type f
find /ds/data_sources/incoming/prescriber/.failed -mtime $days -type f   
