cd_func ()
{
  local x2 the_new_dir adir index
  local -i cnt

  if [[ $1 ==  "--" ]]; then
    dirs -v
    return 0
  fi

  the_new_dir=$1
  [[ -z $1 ]] && the_new_dir=$HOME

  if [[ ${the_new_dir:0:1} == '-' ]]; then
    #
    # Extract dir N from dirs
    index=${the_new_dir:1}
    [[ -z $index ]] && index=1
    adir=$(dirs +$index)
    [[ -z $adir ]] && return 1
    the_new_dir=$adir
  fi

  #
  # '~' has to be substituted by ${HOME}
  [[ ${the_new_dir:0:1} == '~' ]] && the_new_dir="${HOME}${the_new_dir:1}"

  #
  # Now change to the new dir and add to the top of the stack
  pushd "${the_new_dir}" > /dev/null
  [[ $? -ne 0 ]] && return 1
  the_new_dir=$(pwd)

  #
  # Trim down everything beyond 11th entry
  popd -n +11 2>/dev/null 1>/dev/null

  #
  # Remove any other occurence of this dir, skipping the top of the stack
  for ((cnt=1; cnt <= 10; cnt++)); do
    x2=$(dirs +${cnt} 2>/dev/null)
    [[ $? -ne 0 ]] && return 0
    [[ ${x2:0:1} == '~' ]] && x2="${HOME}${x2:1}"
    if [[ "${x2}" == "${the_new_dir}" ]]; then
      popd -n +$cnt 2>/dev/null 1>/dev/null
      cnt=cnt-1
    fi
  done

  return 0
}

change_ds_env() {

	if [ "$1" == dsdev ]
	  then
			BLUELITE_METADATA_LOGIN="dsdev/dsdev@dbi:Oracle:host=$DBHOST;sid=BLUELITE;port=$DBPORT"
			DS_CONNECTION="$BLUELITE_METADATA_LOGIN"
			DS_ENV=dsdev

			export DS_CONNECTION DS_ENV BLUELITE_METADATA_LOGIN
			[ -t 0 ] && echo " -- Data Services Environment (BLUELITE_METADATA_LOGIN) configured for '$DS_ENV'"
	elif [ "$1" == dsprod_old ]
	  then
			BLUELITE_METADATA_LOGIN="bluelite/bluelite@dbi:Oracle:host=ds03;sid=BLUELITE;port=$DBPORT"
			DS_CONNECTION="$BLUELITE_METADATA_LOGIN"
			DS_ENV=dsprod_old

			export DS_CONNECTION DS_ENV BLUELITE_METADATA_LOGIN
			[ -t 0 ] && echo " -- Data Services Environment (BLUELITE_METADATA_LOGIN) configured for '$DS_ENV'"
	elif [ "$1" == dsprod ]
	  then
			BLUELITE_METADATA_LOGIN="bluelite/bluelite@dbi:Oracle:DSPROD"
			EMI_PATIENT_TEST_LOGIN="emi_patient_test/bon[midy@dbi:Oracle:DSPROD"
			EMI_PATIENT_PROD_LOGIN="emi_patient_prod/dy[tagly@dbi:Oracle:DSPROD"
			EMI_PATIENT_QA_LOGIN="emi_patient_qa/ig!woomf@dbi:Oracle:DSPROD"
			DIM_TEST_LOGIN='dim_test/gli6ands@dbi:Oracle:DSPROD'
			DIM_PROD_LOGIN='dim_prod/gli6ands@dbi:Oracle:DSPROD'
			DIM_QA_LOGIN='dim_qa/ur^urkik@dbi:Oracle:DSPROD'
			DW_TEST_LOGIN='dw_test/pr7boogi@dbi:Oracle:DSPROD'
			DW_PBM_TEST_LOGIN='dw_pbm_test/dob9plip@dbi:Oracle:DSPROD'
			DW_PBM_DEV_LOGIN='dw_pbm_dev/kio8ween@dbi:Oracle:DSPROD'
			DW_PBM_CERT_LOGIN='dw_pbm_cert/wig)cuow@dbi:Oracle:DSPROD'
			DW_PBM_PROD_LOGIN='dw_pbm_prod/summer1@dbi:Oracle:DSPROD'
			DW_PROD_LOGIN='dw_prod/pr7boogi@dbi:Oracle:DSPROD'
			DW_QA_LOGIN='dw_qa/cub&oodi@dbi:Oracle:DSPROD'
			DW_AGG_TEST_LOGIN='dw_agg_test/fl0rida1@dbi:Oracle:DSPROD'
			DW_AGG_PROD_LOGIN='dw_agg_prod/wo*tyian@dbi:Oracle:DSPROD'
			CS_DEV_LOGIN='cs_dev/ga6pimuo@dbi:Oracle:DSQA'
			CS_QA_LOGIN='cs_qa/puf9ungr@dbi:Oracle:DSQA'
			DS_ENV=dsprod

			export DS_ENV BLUELITE_METADATA_LOGIN EMI_PATIENT_TEST_LOGIN EMI_PATIENT_PROD_LOGIN DIM_TEST_LOGIN DW_TEST_LOGIN DW_PBM_TEST_LOGIN DW_PBM_DEV_LOGIN DW_PBM_CERT_LOGIN DW_PBM_PROD_LOGIN DIM_PROD_LOGIN DW_PROD_LOGIN EMI_PATIENT_QA_LOGIN DIM_QA_LOGIN DW_QA_LOGIN DW_AGG_TEST_LOGIN DW_AGG_PROD_LOGIN CS_DEV_LOGIN CS_QA_LOGIN
			[ -t 0 ] && echo " -- Data Services Environment (BLUELITE_METADATA_LOGIN) configured for '$DS_ENV'"
	elif [ "$1" != '' ]
	  then
			echo "dont know how to change DS environment to '$1'"
			return 1
	fi

	return 0
}


