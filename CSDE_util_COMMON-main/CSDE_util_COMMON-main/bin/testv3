NEW_PATH=""

for DIR in `echo "$PATH" | tr ":" " "`
do
	if [ -d "$DIR" -a -r "$DIR" ]
	then
		if [ "$NEW_PATH" != "" ]
		then
			NEW_PATH="$NEW_PATH:$DIR"
		else
			NEW_PATH="$DIR"
		fi
	else
		[ "$DEBUG" = "TRUE" ] && echo "Info (DEBUG): Removing $DIR from PATH"
	fi
done

