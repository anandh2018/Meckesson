#!/usr/bin/perl

use strict;
use warnings;

#use lib qw(/ds/development/AuditLog/AuditLog_V0.4.4_alpi_dev/blib/lib /ds/development/NCPDP_Parser/NCPDP_V0.3.1_alpi_dev/blib/lib);

use BLUELITE::TandemSwitchAuditLog::Index_Mgr;
use BLUELITE::Logger;
use Params::Validate qw(:all);

#my $log_file = "/tmp/index_bc.$$.log";
my $log_file = '/dev/null';

initialize_logging(logfile => $log_file, screen_only => 1, screen_threshold => 'INFO');

my $logger = get_logger;

my %option = validate_with
    ( params  => \@ARGV,
      spec    => {  PROCESS_DATE => { type => SCALAR, optional => 0 },
                    INDEX_LIST => { type => SCALAR, optional => 0 },
                    TEMP_DIR => { type => SCALAR, optional => 0 },
										EXIT_SUCCESS => { type => SCALAR, optional => 1, default => 200 },
                    AUDIT_LOG => { type => SCALAR, optional => 0 },
                    AGG_BUCKETS => { type => SCALAR, optional => 0 },
                    BUILD_ID => { type => SCALAR, optional => 0 },
                    CONNECTION_VAR => { type => SCALAR, optional => 0 }
      },
      called  => $0,
      normalize_keys => sub { my $k = shift; $k =~ s/^-//; return uc $k }
    );


my $maint_grp = BLUELITE::TandemSwitchAuditLog::Index_Mgr::Maint_Group->new(temp_dir => $option{TEMP_DIR}, build_id => $option{BUILD_ID}, agg_buckets => $option{AGG_BUCKETS}, dbh_cache_key => 'index_build', dim_pharm_cache_threshold => 1, connection_var => $option{CONNECTION_VAR});

$maint_grp->add_index(split(/\s*,\s*/, $option{INDEX_LIST}));

my $auditlog_parm_name;

if ($option{AUDIT_LOG} =~ /^\d+$/) {
	$auditlog_parm_name = 'audit_log_id';
} else {
	$auditlog_parm_name = 'audit_log';
}


if ($maint_grp->_index_build( process_date => $option{PROCESS_DATE}, $auditlog_parm_name => $option{AUDIT_LOG})) {
	unlink($log_file);
	exit($option{EXIT_SUCCESS});
} else {
	exit(1);
}

