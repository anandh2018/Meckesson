
# make sure slreportd is running on a set of servers

email=dataservicesnotification@relayhealth.com

servers=$*
default_servers='emi rx dsrpt vm hp'

if [ "$servers" = '' ]
  then
		servers="$default_servers"
fi

run_output=`mrun slreportd_ds -- $servers 2>&1`

echo "$run_output"

if echo "$run_output" | grep -i error > /dev/null
  then
		echo "$run_output" | mailx -s 'slreportd failure' $email
		exit 1
  else
		exit 0
fi
